rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Any signed-in Google user can read and write sites and tasks.
    // To restrict to specific email domains, change the condition below, e.g.:
    //   request.auth.token.email.matches(".*@yourcompany.com")
    match /sites/{siteId} {
      allow read, write: if request.auth != null;
    }
    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
    }
  }
}
